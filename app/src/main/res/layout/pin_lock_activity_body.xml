<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="24dp"
    android:focusable="false"
    android:focusableInTouchMode="false"
    android:clickable="false">

    <TextView
        android:id="@+id/pinLockTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enter PIN"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="?bluelineconsoleBaseTextColor"
        android:layout_marginBottom="16dp"
        />

    <TextView
        android:id="@+id/pinLockIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="32sp"
        android:textColor="?bluelineconsoleAccentColor"
        android:layout_marginBottom="24dp"
        />

    <!-- Keyboard Grid -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        >
        <!-- Row 1 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            >
            <TextView android:id="@+id/btn1" android:text="1" style="@style/PinKeyStyle"/>
            <TextView android:id="@+id/btn2" android:text="2" style="@style/PinKeyStyle"/>
            <TextView android:id="@+id/btn3" android:text="3" style="@style/PinKeyStyle"/>
        </LinearLayout>
        <!-- Row 2 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            >
            <TextView android:id="@+id/btn4" android:text="4" style="@style/PinKeyStyle"/>
            <TextView android:id="@+id/btn5" android:text="5" style="@style/PinKeyStyle"/>
            <TextView android:id="@+id/btn6" android:text="6" style="@style/PinKeyStyle"/>
        </LinearLayout>
        <!-- Row 3 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            >
            <TextView android:id="@+id/btn7" android:text="7" style="@style/PinKeyStyle"/>
            <TextView android:id="@+id/btn8" android:text="8" style="@style/PinKeyStyle"/>
            <TextView android:id="@+id/btn9" android:text="9" style="@style/PinKeyStyle"/>
        </LinearLayout>
        <!-- Row 4 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            >
            <TextView android:id="@+id/btnDelete" android:text="DEL" style="@style/PinKeyActionStyle"/>
            <TextView android:id="@+id/btn0" android:text="0" style="@style/PinKeyStyle"/>
            <TextView android:id="@+id/btnCancel" android:text="ESC" style="@style/PinKeyActionStyle"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
