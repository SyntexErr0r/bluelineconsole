<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Basic definition for light and dark -->

    <style name="BaseAppThemeLight" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="android:colorBackground">@color/baseBackground</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:windowAnimationStyle">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="bluelineconsoleAccentColor">@color/colorAccent</item>
        <item name="bluelineconsoleBaseTextColor">@color/baseText</item>
        <item name="bluelineconsoleDisabledTextColor">@color/disabledText</item>
        <item name="bluelineconsoleSelectedItemBackgroundColor">@color/selectedItemBackground</item>
        <item name="bluelineconsoleBackgroundColorOfCommand">@color/colorBackgroundOfCommand</item>
    </style>

    <style name="BaseAppThemeDark" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="android:colorBackground">@color/baseBackgroundDark</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:windowAnimationStyle">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="bluelineconsoleAccentColor">@color/colorAccentDark</item>
        <item name="bluelineconsoleBaseTextColor">@color/baseTextDark</item>
        <item name="bluelineconsoleDisabledTextColor">@color/disabledTextDark</item>
        <item name="bluelineconsoleSelectedItemBackgroundColor">@color/selectedItemBackgroundDark</item>
        <item name="bluelineconsoleBackgroundColorOfCommand">@color/colorBackgroundOfCommandDark</item>
    </style>

    <style name="PinKeyStyle">
        <item name="android:layout_width">72dp</item>
        <item name="android:layout_height">72dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textColor">?bluelineconsoleBaseTextColor</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:background">?android:attr/selectableItemBackground</item>
    </style>

    <style name="PinKeyActionStyle">
        <item name="android:layout_width">72dp</item>
        <item name="android:layout_height">72dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">?bluelineconsoleAccentColor</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:background">?android:attr/selectableItemBackground</item>
    </style>
</resources>
